# Elastic Stack Version
STACK_VERSION=8.17.0

# Elasticsearch settings
ELASTIC_PASSWORD=changeme
CLUSTER_NAME=es-cluster
LICENSE=basic
ES_PORT=9200
ES_MEM_LIMIT=2147483648

# Kibana settings
KIBANA_PORT=5601
KIBANA_MEM_LIMIT=1073741824

# Fleet Server settings
FLEET_PORT=8220
FLEET_MEM_LIMIT=1073741824

# Internal service hostnames for inter-container communication
# Docker / Podman network mode (default): use container names
# Podman pod mode (old podman-compose without --no-pod): change all to "localhost"
INT_ES_HOST=es01
INT_KIBANA_HOST=kibana
INT_FLEET_HOST=fleet-server

# Agent enrollment settings
# Local mode (agent on same host as Fleet Server): defaults work automatically
# Remote mode (agent on different host): set these to the Fleet Server host's address
FLEET_URL=https://fleet-server:8220
KIBANA_URL=http://localhost:5601
ES_URL=https://localhost:9200
# Path to CA certificate file (required for remote agents)
# Extract from Fleet Server host: docker cp fleet-server:/certs/ca/ca.crt ./ca.crt
CA_CERT=

# Encryption keys (generate your own for production: openssl rand -hex 32)
ENCRYPTION_KEY=changeme
